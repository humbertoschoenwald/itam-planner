{
  "$schema": "https://turborepo.dev/schema.json",
  "globalDependencies": [
    "package.json",
    "pnpm-lock.yaml",
    "turbo.json"
  ],
  "globalEnv": [
    "CI",
    "NODE_ENV",
    "FORCE_JAVASCRIPT_ACTIONS_TO_NODE24"
  ],
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        ".next/**",
        "dist/**",
        "build/**"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "outputs": []
    },
    "test": {
      "outputs": []
    },
    "test:coverage": {
      "outputs": [
        "coverage/**"
      ]
    },
    "typecheck": {
      "outputs": []
    }
  }
}
