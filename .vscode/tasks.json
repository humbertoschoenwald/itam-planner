{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Web: Dev Server",
      "type": "shell",
      "command": "pnpm dev:web",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": ".+",
          "message": 0
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*(Starting|Ready|Local:).*",
          "endsPattern": ".*(Ready in|Local:).*$"
        }
      },
      "presentation": {
        "clear": true,
        "panel": "dedicated",
        "reveal": "always"
      },
      "runOptions": {
        "reevaluateOnRerun": true
      }
    },
    {
      "label": "Web: Responsive Smoke",
      "type": "shell",
      "command": "pnpm test:web:responsive",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "clear": true,
        "panel": "dedicated",
        "reveal": "always"
      }
    },
    {
      "label": "Web: Responsive Smoke (Headed)",
      "type": "shell",
      "command": "pnpm test:web:responsive:headed",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "clear": true,
        "panel": "dedicated",
        "reveal": "always"
      }
    },
    {
      "label": "Web: Responsive Smoke UI",
      "type": "shell",
      "command": "pnpm test:web:responsive:ui",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "clear": true,
        "panel": "dedicated",
        "reveal": "always"
      }
    },
    {
      "label": "Repository: Local CI",
      "type": "shell",
      "command": "pnpm ci:local",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "clear": true,
        "panel": "dedicated",
        "reveal": "always"
      }
    }
  ]
}
