; ADR-0000 and ADR-0006 are the canonical sources for this file.
; This file contains only derived formatting policy.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_size = 2
max_line_length = 100

[*.py]
indent_size = 4
max_line_length = 100

[*.md]
trim_trailing_whitespace = false
max_line_length = off

[Makefile]
indent_style = tab

[*.{sh,bash,mjs}]
indent_size = 2
end_of_line = lf

[*.{yml,yaml,json,jsonc,toml}]
indent_size = 2
