#!/bin/sh

set -eu

origin_push_url="$(git remote get-url --push origin 2>/dev/null || true)"

case "$origin_push_url" in
  ""|git@*|ssh://*)
    ;;
  *)
    if [ "${ALLOW_NON_SSH_PUSH:-0}" != "1" ]; then
      echo "pre-push: non-SSH push URL detected for origin: $origin_push_url" >&2
      echo "pre-push: restore an SSH push URL or set ALLOW_NON_SSH_PUSH=1 only when explicitly instructed." >&2
      exit 1
    fi
    ;;
esac

required_files="
AGENTS.md
docs/adr/README.md
docs/adr/0000-repository-doctrine.md
docs/adr/0006-quality-gates-and-automation.md
.cursor/rules/00-bootstrap-and-authority.mdc
"

for path in $required_files; do
  if [ ! -f "$path" ]; then
    echo "pre-push: required doctrine artifact is missing: $path" >&2
    exit 1
  fi
done

tracked_files="$(git ls-files)"

if [ -z "$tracked_files" ]; then
  exit 0
fi

for path in $tracked_files; do
  if [ -f "$path" ] && [ ! -s "$path" ]; then
    echo "pre-push: tracked empty file is not allowed: $path" >&2
    exit 1
  fi
done
