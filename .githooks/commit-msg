#!/bin/sh

set -eu

message_file="$1"
message="$(head -n 1 "$message_file")"

case "$message" in
  Merge\ *|Revert\ *)
    exit 0
    ;;
esac

pattern='^(feat|fix|docs|style|refactor|test|build|ci|chore|perf|revert)(\([a-z0-9._/-]+\))?!?: .+'

if printf '%s' "$message" | grep -Eq "$pattern"; then
  exit 0
fi

echo "commit-msg: expected Conventional Commit format." >&2
echo "commit-msg: example: docs(repo): add ADR doctrine baseline" >&2
exit 1
